/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-s1\u003es\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=pl-s1\u003es\u003c/span\u003e \u003cspan class=pl-c1\u003e!=\u003c/span\u003e \u003cspan class=pl-c1\u003enull\u003c/span\u003e ? \u003cspan class=pl-s1\u003es\u003c/span\u003e\u003cspan class=pl-kos\u003e.\u003c/span\u003e\u003cspan class=pl-en\u003etoLocaleString\u003c/span\u003e\u003cspan class=pl-kos\u003e(\u003c/span\u003e\u003cspan class=pl-kos\u003e)\u003c/span\u003e : \u003cspan class=pl-s\u003e\u0026#39;\u0026lt;span class=\u0026quot;no-data\u0026quot;\u0026gt;—\u0026lt;/span\u0026gt;\u0026#39;\u003c/span\u003e\u003cspan class=pl-kos\u003e;\u003c/span\u003e","\u003cspan class=pl-k\u003econst\u003c/span\u003e \u003cspan class=pl-c1\u003eSL\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-kos\u003e{\u003c/span\u003e \u003cspan class=pl-c1\u003enew\u003c/span\u003e:\u003cspan class=pl-s\u003e\u0026#39;新增持股\u0026#39;\u003c/span\u003e\u003cspan class=pl-kos\u003e,\u003c/span\u003e \u003cspan class=pl-c1\u003eadd\u003c/span\u003e:\u003cspan class=pl-s\u003e\u0026#39;增加\u0026#39;\u003c/span\u003e\u003cspan class=pl-kos\u003e,\u003c/span\u003e \u003cspan class=pl-c1\u003edec\u003c/span\u003e:\u003cspan class=pl-s\u003e\u0026#39;減少\u0026#39;\u003c/span\u003e\u003cspan class=pl-kos\u003e,\u003c/span\u003e \u003cspan class=pl-c1\u003eout\u003c/span\u003e:\u003cspan class=pl-s\u003e\u0026#39;完全出清\u0026#39;\u003c/span\u003e\u003cspan class=pl-kos\u003e,\u003c/span\u003e \u003cspan class=pl-c1\u003esame\u003c/span\u003e:\u003cspan class=pl-s\u003e\u0026#39;不變\u0026#39;\u003c/span\u003e \u003cspan class=pl-kos\u003e}\u003c/span\u003e\u003cspan class=pl-kos\u003e;\u003c/span\u003e","\u003cspan class=pl-k\u003econst\u003c/span\u003e \u003cspan class=pl-c1\u003eSC\u003c/span\u003e \u003cspan class=pl-c1\u003e=\u003c/span\u003e \u003cspan class=pl-kos\u003e{\u003c/s